# Supabase is optional. Leave these empty to run in demo mode.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Fallback key name supported by the app if VITE_SUPABASE_PUBLISHABLE_KEY is not set.
# VITE_SUPABASE_ANON_KEY=

# Production AI Upload should call a server-side proxy such as:
# https://<project-ref>.functions.supabase.co/ai-vision-proxy
# Store third-party AI provider credentials as Supabase Edge Function secrets, not Vite env vars.
